  <version>0.1.0</version>
  <date>2026-04-12</date>
  <maintainer email="">Bradley Corner</maintainer>
  <license file="LICENSE">MIT</license>
  <url type="repository" branch="main">https://github.com/bradleycorner/maker-ops</url>

  <content>
    <workbench>
      <classname>MakerOpsWorkbench</classname>
      <subdirectory>./</subdirectory>
      <tag>manufacturing</tag>
      <tag>cost</tag>
      <freecadmin>0.21</freecadmin>
    </workbench>
  </content>
</package>
